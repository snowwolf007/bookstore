<view class="page">
  <view class="user-card">
    <view class="avatar">👤</view>
    <view class="user-info">
      <view class="name">书友</view>
      <view class="desc">建筑书店</view>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="toOrders">
      <text class="icon">📦</text>
      <text class="label">我的订单</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="toAddress">
      <text class="icon">📍</text>
      <text class="label">收货地址</text>
      <text class="arrow">›</text>
    </view>
    <view class="menu-item" bindtap="toFavorites">
      <text class="icon">❤️</text>
      <text class="label">我的收藏</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="menu-list" style="margin-top:12px">
    <view class="menu-item" bindtap="about">
      <text class="icon">ℹ️</text>
      <text class="label">关于我们</text>
      <text class="arrow">›</text>
    </view>
  </view>

  <view class="footer-text">厦门建筑书店 · 原版建筑图书</view>
</view>
