/* 分类页 */
.page { height: 100vh; display: flex; }
.layout { display: flex; height: 100%; width: 100%; }

.left {
  width: 100px;
  background: #fff;
  flex-shrink: 0;
  height: 100%;
}
.left .cat-item {
  padding: 16px 12px;
  font-size: 14px;
  color: #555;
  display: flex;
  align-items: center;
  gap: 6px;
  border-bottom: 1px solid #f0ede8;
  position: relative;
}
.left .cat-item.active {
  color: #2c3e50;
  font-weight: 600;
  background: #f8f5f0;
}
.left .cat-item.active .cat-dot {
  width: 3px;
  height: 16px;
  background: #2c3e50;
  border-radius: 2px;
  position: absolute;
  left: 0;
}
.cat-dot { width: 3px; height: 16px; flex-shrink: 0; }
.count { font-size: 11px; color: #ccc; margin-left: auto; }

.right {
  flex: 1;
  padding: 12px;
  height: 100%;
}
