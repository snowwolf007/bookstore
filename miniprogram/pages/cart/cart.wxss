/* 购物车 */
.page { padding-bottom: 80px; }
.sub { font-size: 13px; color: #bbb; margin-top: 4px; }
.btn-go { margin-top: 16px; width: 140px; height: 40px; line-height: 40px; background: #2c3e50; color: #fff; border-radius: 20px; font-size: 14px; display: inline-block; }

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 12px;
  margin: 0 0 1px;
  gap: 12px;
}
.cart-item .cover {
  width: 60px;
  height: 80px;
  border-radius: 4px;
  background: #f0ede8;
  flex-shrink: 0;
}
.cart-item .info {
  flex: 1;
}
.cart-item .title {
  font-size: 14px;
  color: #222;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cart-item .price {
  font-size: 16px;
  font-weight: 600;
  color: #c0392b;
  margin-top: 4px;
}
.qty-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-top: 6px;
}
.qty-btn {
  width: 26px;
  height: 26px;
  line-height: 26px;
  text-align: center;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 16px;
  color: #555;
}
.qty-num {
  font-size: 14px;
  color: #333;
  min-width: 20px;
  text-align: center;
}
.del {
  padding: 8px;
  color: #ccc;
  font-size: 14px;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px;
  background: #fff;
  box-shadow: 0 -2px 8px rgba(0,0,0,.06);
}
.total {
  font-size: 14px;
  color: #333;
}
.total-price {
  font-size: 22px;
  font-weight: 700;
  color: #c0392b;
}
.btn-checkout {
  width: 120px;
  height: 42px;
  line-height: 42px;
  background: #c0392b;
  color: #fff;
  border-radius: 21px;
  font-size: 15px;
  border: none;
}
