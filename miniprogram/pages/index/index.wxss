/* 首页样式 */
page {
  background: #f8f5f0;
}
.page { padding-bottom: 20px; }

/* 轮播 */
.banner {
  height: 200px;
}
.banner-item {
  position: relative;
  width: 100%;
  height: 200px;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
  background: #ddd;
}
.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px;
  background: linear-gradient(transparent, rgba(0,0,0,.6));
  color: #fff;
  font-size: 14px;
  line-height: 1.4;
}

/* 分区 */
.section {
  margin: 16px 14px 0;
}

/* 错误提示 */
.error-box {
  background: #fff3e0;
  border: 1px solid #ffe0b2;
  border-radius: 8px;
  padding: 20px;
  text-align: center;
  margin: 10px 0;
}
.error-icon { font-size: 32px; margin-bottom: 8px; }
.error-text { font-size: 13px; color: #e65100; line-height: 1.6; }
.retry-btn { margin-top: 12px; display: inline-block; padding: 8px 24px; background: #e65100; color: #fff; border-radius: 20px; font-size: 14px; }

.section-title {
  font-size: 17px;
  font-weight: 600;
  color: #222;
  margin-bottom: 12px;
  padding-left: 4px;
  border-left: 3px solid #2c3e50;
  padding-left: 10px;
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  background: #fff;
  border-radius: 10px;
  padding: 16px 8px;
  box-shadow: 0 1px 4px rgba(0,0,0,.04);
}
.cat-item {
  text-align: center;
  padding: 6px 0;
}
.cat-icon {
  font-size: 28px;
  margin-bottom: 4px;
}
.cat-name {
  font-size: 12px;
  color: #666;
}
