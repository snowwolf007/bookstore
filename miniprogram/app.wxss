/* ===== 全局样式 ===== */
page {
  background-color: #f8f5f0;
  font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
  color: #333;
}

/* ===== 书籍卡片（复用） ===== */
.book-card {
  background: #fff;
  border-radius: 8px;
  overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,.06);
  margin-bottom: 12px;
  display: flex;
  padding: 12px;
}
.book-card .cover {
  width: 88px;
  height: 118px;
  border-radius: 4px;
  flex-shrink: 0;
  background: #f0ede8;
  object-fit: cover;
}
.book-card .info {
  flex: 1;
  margin-left: 12px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 118px;
}
.book-card .title {
  font-size: 16px;
  font-weight: 500;
  color: #222;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.book-card .author {
  font-size: 13px;
  color: #999;
  margin-top: 4px;
}
.book-card .meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8px;
}
.book-card .price {
  font-size: 18px;
  font-weight: 600;
  color: #c0392b;
}
.book-card .price .symbol {
  font-size: 12px;
}
.book-card .tag {
  font-size: 11px;
  color: #fff;
  background: #2c3e50;
  padding: 2px 8px;
  border-radius: 10px;
}

/* ===== 空状态 ===== */
.empty-state {
  text-align: center;
  padding: 60px 20px;
  color: #bbb;
}
.empty-state .icon {
  font-size: 48px;
  margin-bottom: 12px;
}
.empty-state .text {
  font-size: 14px;
}

/* ===== 加载 ===== */
.loading {
  text-align: center;
  padding: 30px;
  color: #999;
}

/* ===== 搜索框 ===== */
.search-bar {
  background: #fff;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.search-bar input {
  flex: 1;
  height: 36px;
  background: #f0ede8;
  border-radius: 18px;
  padding: 0 16px;
  font-size: 14px;
}
.search-bar .btn {
  font-size: 14px;
  color: #2c3e50;
  white-space: nowrap;
}
